{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": {
      "value": "${AZURE_ENV_NAME}"
    },
    "location": {
      "value": "${AZURE_LOCATION}"
    },
    "aiLocation": {
      "value": "${AZURE_AI_LOCATION=canadacentral}"
    },
    "principalId": {
      "value": "${AZURE_PRINCIPAL_ID}"
    },
    "entraApiClientId": {
      "value": "${ENTRA_API_CLIENT_ID}"
    },
    "entraApiClientSecret": {
      "value": "${ENTRA_API_CLIENT_SECRET}"
    },
    "entraSpaClientId": {
      "value": "${ENTRA_SPA_CLIENT_ID}"
    },
    "entraRequiredScope": {
      "value": "${ENTRA_REQUIRED_SCOPE=access_as_user}"
    },
    "chatModelName": {
      "value": "${CHAT_MODEL_NAME=gpt-4o}"
    },
    "chatModelVersion": {
      "value": "${CHAT_MODEL_VERSION=2024-11-20}"
    },
    "categorizeModelName": {
      "value": "${CATEGORIZE_MODEL_NAME=gpt-4o-mini}"
    },
    "categorizeModelVersion": {
      "value": "${CATEGORIZE_MODEL_VERSION=2024-07-18}"
    },
    "embeddingModelName": {
      "value": "${EMBEDDING_MODEL_NAME=text-embedding-3-large}"
    },
    "embeddingModelVersion": {
      "value": "${EMBEDDING_MODEL_VERSION=1}"
    },
    "appServicePlanSku": {
      "value": "${APP_SERVICE_PLAN_SKU=B2}"
    }
  }
}
